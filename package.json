  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "e2e": "playwright test",
    "e2e:serve": "vite preview --host localhost --port 4174 --strictPort",
    "format:all": "npm exec -- prettier --write .",
    "format:all:check": "npm exec -- prettier --check .",
    "prepare": "node ./scripts/install-git-hooks.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "marked": "^17.0.4",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
